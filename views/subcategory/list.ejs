<!DOCTYPE html>
<html lang="en">

<head>
    <title>Subcategories</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <a class="navbar-brand" href="/dashboard">Admin Panel</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item"><a class="nav-link" href="/dashboard">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
                <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
                <li class="nav-item active"><a class="nav-link" href="/subcategories">Subcategories</a></li>
                <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
            </ul>
            <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">Manage Subcategories</h2>
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <form action="/subcategories/add" method="POST" class="form-inline">
                    <input type="text" name="name" class="form-control mr-2" placeholder="Subcategory Name" required>
                    <select name="parentId" class="form-control mr-2" required>
                        <option value="">Select Main Category</option>
                        <% mainCategories.forEach(cat=> { %>
                            <option value="<%= cat._id %>">
                                <%= cat.name %>
                            </option>
                            <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary">Add Subcategory</button>
                </form>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead class="thead-dark">
                <tr>
                    <th>Subcategory Name</th>
                    <th>Associated Main Category</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% subcategories.forEach(sub=> { %>
                    <tr>
                        <td>
                            <%= sub.name %>
                        </td>
                        <td>
                            <%= sub.parentCategory ? sub.parentCategory.name : 'N/A' %>
                        </td>
                        <td>
                            <a href="/subcategories/edit/<%= sub._id %>" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/subcategories/delete/<%= sub._id %>" class="btn btn-sm btn-danger"
                                onclick="return confirm('Are you sure?')">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>
</body>

</html>