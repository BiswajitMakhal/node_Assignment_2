<!DOCTYPE html>
<html lang="en">
<head>
    <title>Edit Subcategory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">Edit Subcategory</div>
                    <div class="card-body">
                        <form action="/subcategories/edit/<%= subcategory._id %>" method="POST">
                            <div class="form-group">
                                <label>Subcategory Name</label>
                                <input type="text" name="name" class="form-control" value="<%= subcategory.name %>" required>
                            </div>
                            <div class="form-group">
                                <label>Parent Category</label>
                                <select name="parentId" class="form-control" required>
                                    <% mainCategories.forEach(cat => { %>
                                        <option value="<%= cat._id %>" <%= subcategory.parentId.toString() === cat._id.toString() ? 'selected' : '' %>>
                                            <%= cat.name %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-warning">Update Subcategory</button>
                            <a href="/subcategories" class="btn btn-secondary">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>