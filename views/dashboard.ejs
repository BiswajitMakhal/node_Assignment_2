<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <a class="navbar-brand" href="/dashboard">Admin Panel</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item active"><a class="nav-link" href="/dashboard">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
                <li class="nav-item"><a class="nav-link" href="/categories">Categories</a></li>
                <li class="nav-item"><a class="nav-link" href="/subcategories">Subcategories</a></li>
                <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
            </ul>
            <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="mb-4">Dashboard Statistics</h2>
        <div class="row text-center mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-info mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Total Products</h5>
                        <h2><%= totalProducts %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Total Categories</h5>
                        <h2><%= totalCategories %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-warning mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Total Subcategories</h5>
                        <h2><%= totalSubcategories %></h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <h4>Products by Category</h4>
                <ul class="list-group">
                    <% productsByCategory.forEach(item => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <%= item.categoryName %>
                            <span class="badge badge-primary badge-pill"><%= item.count %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>
            <div class="col-md-6">
                <h4>Products by Subcategory</h4>
                <ul class="list-group">
                    <% productsBySubcategory.forEach(item => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <%= item.subCategoryName %>
                            <span class="badge badge-primary badge-pill"><%= item.count %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>